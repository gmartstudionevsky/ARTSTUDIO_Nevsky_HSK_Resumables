{
  "name": "artstudio-consumables",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d db",
    "prisma:studio": "DIRECT_URL=${DIRECT_URL:-$DATABASE_URL} prisma studio",
    "seed": "tsx prisma/seed.ts",
    "pretypecheck": "npm run prisma:generate",
    "prebuild": "npm run prisma:generate",
    "prisma:migrate:deploy": "DIRECT_URL=${DIRECT_URL:-$DATABASE_URL} prisma migrate deploy",
    "prisma:generate": "DIRECT_URL=${DIRECT_URL:-$DATABASE_URL} prisma generate",
    "seed:defaults": "tsx prisma/seed.ts defaults",
    "seed:staging": "tsx prisma/seed.ts staging",
    "seed:test:e2e": "tsx prisma/seed.ts test-e2e",
    "seed:bootstrap-admin": "tsx prisma/seed.ts bootstrap-admin",
    "testdb:reset:local-e2e": "tsx scripts/testdb/reset-local-e2e.ts",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:local": "npm run testdb:reset:local-e2e && npm run test:e2e",
    "verify": "npm run prisma:generate && npm run lint && npm run typecheck && npm run build",
    "start:e2e": "next start -H 127.0.0.1 -p 3000"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.16.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.469.0",
    "next": "^14.2.5",
    "prisma": "^6.16.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.2",
    "tsx": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "postcss": "^8.4.39",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
