# Local development defaults
NODE_ENV=development
SESSION_SECRET=replace-with-strong-random-secret

# Runtime DB URL (Vercel runtime uses DATABASE_URL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/artstudio_consumables?schema=public

# Prisma migrations URL (CI migrate workflows use DIRECT_URL)
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/artstudio_consumables?schema=public

# Public URL is optional and used only where explicitly needed
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=https://artstudio-consumables.vercel.app

# Production jobs/digest only
JOB_SECRET=

# Optional Telegram integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# Explicit one-time admin bootstrap only (never fallback)
SEED_ADMIN_LOGIN=admin
SEED_ADMIN_PASSWORD=

# Deterministic E2E test user (local/CI test DB only)
E2E_USER_LOGIN=e2e_admin
E2E_USER_PASSWORD=E2EPass12345!

# Allow http cookie mode for local Playwright against 127.0.0.1
E2E_ALLOW_INSECURE_COOKIE=true
