POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=artstudio_consumables

# Runtime connection (pooler/serverless). Use STAGING_DATABASE_URL in staging CI/e2e.
DATABASE_URL=postgresql://postgres.[POOLER_PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
# Direct connection for Prisma migrate/seed only (5432). Use STAGING_DIRECT_URL for staging migrations.
DIRECT_URL=postgresql://postgres.[DB_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require
SESSION_SECRET=replace-with-strong-random-secret

NODE_ENV=development
SEED_ADMIN_PASSWORD=ChangeMe123!
APP_URL=http://localhost:3000
TELEGRAM_BOT_TOKEN=
JOB_SECRET=
TELEGRAM_DEFAULT_CHAT_ID=
